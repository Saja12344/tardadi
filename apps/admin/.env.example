# TARDADI_API_URL=http://127.0.0.1:5001/demo-org/us-central1/api
# TARDADI_ORG_ID=demo-org

# Optional — attach to upstream when backend admin auth is enabled:
# ADMIN_API_TOKEN=

# Optional — Google Places (same results as Google Maps search):
# GOOGLE_MAPS_API_KEY=

# ⚠️  Do NOT put secrets in NEXT_PUBLIC_* variables — they are exposed to the browser.
