rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isBusinessAdmin(businessId) {
      return isSignedIn()
        && request.auth.token.role == 'business_admin'
        && request.auth.token.businessId == businessId;
    }

  match /admin_users/{userId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /businesses/{businessId} {
      allow read: if isSuperAdmin() || isBusinessAdmin(businessId);
      allow create, update, delete: if isSuperAdmin();

      match /drivers/{docId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isBusinessAdmin(businessId);
      }

      match /buses/{docId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isBusinessAdmin(businessId);
      }

      match /routes/{routeId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isBusinessAdmin(businessId);

        match /stops/{stopId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isBusinessAdmin(businessId);
        }
      }

      match /trips/{tripId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isBusinessAdmin(businessId);

        match /gps_logs/{logId} {
          allow read: if true;
          allow create: if isSuperAdmin() || isBusinessAdmin(businessId);
          allow update, delete: if false;
        }
      }

      match /reminders/{reminderId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if isSuperAdmin() || isBusinessAdmin(businessId);
      }
    }
  }
}
